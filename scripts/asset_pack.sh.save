#!/usr/bin/env bash
set -e

# GLOBAL-ANYWHERE VERSION — always run from your project root
PROJECT_ROOT="/Users/gt/Projects/shopconnect"

# Always switch to project root before doing anything
cd "$PROJECT_ROOT"

echo "📂 Project root: $PROJECT_ROOT"

# Version file
VERSION_FILE="$PROJECT_ROOT/VERSION"

# Get current version or default
if [ -f "$VERSION_FILE" ]; then
  CURRENT_VERSION="$(cat "$VERSION_FILE" | tr -d '[:space:]')"
else
  CURRENT_VERSION="v1.0.0"
fi

# Auto-increment PATCH only (vX.Y.Z)
BASE="${CURRENT_VERSION#v}"
MAJOR="$(echo "$BASE" | cut -d. -f1)"
MINOR="$(echo "$BASE" | cut -d. -f2)"
PATCH="$(echo "$BASE" | cut -d. -f3)"
PATCH=$((PATCH + 1))
NEW_VERSION="v${MAJOR}.${MINOR}.${PATCH}"

# Timestamp: YYYY.MM.DD-HHMM
TIMESTAMP="$(date +"%Y.%m.%d-%H%M")"

ZIP_NAME="shopconnect_assets_${NEW_VERSION}_${TIMESTAMP}.zip"

echo "$NEW_VERSION" > "$VERSION_FILE"
echo "🔢 Version: $NEW_VERSION"
echo "⏱  Timestamp: $TIMESTAMP"
echo "📦 ZIP: $ZIP_NAME"

echo "🔍 Checking asset folders..."
mkdir -p assets/icon
mkdir -p assets/logos
mkdir -p assets/data

echo "🔧 Ensuring launcher icon exists..."
if [ ! -f assets/icon/app_icon.png ]; then
  echo "⚠️  app_icon.png missing — using fallback from logos if 
available..."
  if [ -f assets/logos/sephora.png ]; then
    cp assets/logos/sephora.png assets/icon/app_icon.png
  fi
fi

echo "📦 Cleaning dist folder..."
rm -rf dist
mkdir -p dist/assets

echo "📁 Copying logos..."
[ -d assets/logos ] && cp -R assets/logos dist/assets/

echo "📁 Copying splash screens..."
[ -d assets/splash ] && cp -R assets/splash dist/assets/

echo "📁 Copying screenshots..."
if [ -d assets/screenshots ]; then
  mkdir -p dist/assets/screenshots
  [ -d assets/screenshots/ios ] && cp -R assets/screenshots/ios 
dist/assets/screenshots/
  [ -d assets/screenshots/android ] && cp -R assets/screenshots/android 
dist/assets/screenshots/
fi

echo "📁 Copying marketing banners..."
if [ -d assets/marketing ]; then
  mkdir -p dist/assets/marketing
  [ -d assets/marketing/banners ] && cp -R assets/marketing/banners 
dist/assets/marketing/
fi

echo "📁 Copying icons..."
[ -d assets/icon ] && cp -R assets/icon dist/assets/

echo "🔄 Running Flutter asset tools..."
flutter pub get
dart run flutter_launcher_icons
dart run flutter_native_splash:create

echo "🗜️ Creating ZIP..."
cd dist
zip -r "../$ZIP_NAME" assets > /dev/null
cd ..

echo "✅ Done."
echo "📦 Output: $ZIP_NAME"

